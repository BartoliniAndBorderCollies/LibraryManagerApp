@model LibraryManagerApp.Models.ViewModels.CategoryIndexViewModel

@{
	ViewData["Title"] = "Categories";
}

<section class="categories-page">



	<div class="categories-form-box">



		<h2>Dodaj nową kategorię</h2>

		<form asp-controller="Category" asp-action="Add" method="post">
			@Html.AntiForgeryToken()

			<div class="form-group">
				<label for="name">Nazwa: </label>
				<input type="text" id="name" name="Name" class="form-control" />
			</div>

			<div class="form-group">
				<button type="submit" class="btn btn-primary general-settings-btn">Dodaj</button>
			</div>


		</form>

	</div>





	<div class="categories-table-box">



		<h2>Lista dostępnych kategorii: </h2>


		@* ta klasa jest z bootstrapa *@
		<table class="table table-bordered">

			<thead>

				<tr>

					<th>Id</th>
					<th>Name</th>
					<th>Akcje</th>

				</tr>

			</thead>

			<tbody>

				@foreach (var category in Model.Categories)
				{
					<tr>

						<td>@category.CategoryId</td>
						<td>@category.Name</td>
						<td>

							<form asp-controller="Category" asp-action="Delete" method="post" style="display:inline;">
								@Html.AntiForgeryToken()

								<input type="hidden" name="id" value="@category.CategoryId" />
								<button type="submit" class="btn btn-link p-0" onclick="return confirm('Czy na pewno usunąć tę kategorię?')">Usuń</button>


							</form>

						</td>

					</tr>

				}

			</tbody>


		</table>


	</div>

</section>
