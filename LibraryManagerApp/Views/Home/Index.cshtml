@{
	ViewData["Title"] = "Home Page";
}

<section class="home-hero">
	<img src="~/images/library main.png" alt="Library System" class="home-hero-image" />



	<div class="home-main-box">


		<div class="text-center">

			<h2>Logowanie: </h2>

			<form asp-controller="Home" asp-action="Login" method="post">



				<div class="form-group mb-3">
					<label for="login">Login</label>
					<input type="text" id="login" name="Login" class="form-control home-login-input" />
				</div>

				<div class="form-group mb-3">
					<label for="password">Password</label>
					<input type="password" id="password" name="Password" class="form-control home-login-input" />

				</div>



				<button type="submit" class="btn btn-primary">Log in</button>

				<a class="btn btn-secondary">I forgot login/password</a>


			</form>

		</div>



	</div>
</section>