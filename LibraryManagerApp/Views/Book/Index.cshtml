@model LibraryManagerApp.Models.ViewModels.BookIndexViewModel

@{
    ViewData["Title"] = "Books";
}

<section class="books-page">
    <div class="books-table-box">
        <h2>Lista książek</h2>

        <form asp-controller="Book" asp-action="Update" method="post">
            @Html.AntiForgeryToken()

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Tytuł</th>
                        <th>Kategoria</th>
                        <th>Rok wydania</th>
                        <th>ISBN</th>
                        <th>Wydawca</th>
                        <th>Liczba stron</th>
                        <th>Dostępna</th>
                        <th>Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model.Books)
                    {
                        <tr>
                            <td>
                                @book.BookId
                                @if (Model.EditingBookId == book.BookId)
                                {
                                    <input type="hidden" name="BookId" value="@book.BookId" />
                                }
                            </td>

                            <td>
                                @if (Model.EditingBookId == book.BookId)
                                {
                                    <input type="text" name="Title" value="@book.Title" class="form-control" />
                                }
                                else
                                {
                                    @book.Title
                                }
                            </td>

                            <td>
                                @if (Model.EditingBookId == book.BookId)
                                {
                                    <select name="CategoryId" class="form-control">
                                        @foreach (var category in Model.Categories)
                                        {
                                            @if (category.CategoryId == book.CategoryId)
                                            {
                                                <option value="@category.CategoryId" selected>@category.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@category.CategoryId">@category.Name</option>
                                            }
                                        }
                                    </select>
                                }
                                else
                                {
                                    @book.Category?.Name
                                }
                            </td>

                            <td>
                                @if (Model.EditingBookId == book.BookId)
                                {
                                    <input type="number" name="PublishYear" value="@book.PublishYear" class="form-control" />
                                }
                                else
                                {
                                    @book.PublishYear
                                }
                            </td>

                            <td>
                                @if (Model.EditingBookId == book.BookId)
                                {
                                    <input type="text" name="ISBN" value="@book.ISBN" class="form-control" />
                                }
                                else
                                {
                                    @book.ISBN
                                }
                            </td>

                            <td>
                                @if (Model.EditingBookId == book.BookId)
                                {
                                    <input type="text" name="Publisher" value="@book.Publisher" class="form-control" />
                                }
                                else
                                {
                                    @book.Publisher
                                }
                            </td>

                            <td>
                                @if (Model.EditingBookId == book.BookId)
                                {
                                    <input type="number" name="PagesNumber" value="@book.PagesNumber" class="form-control" />
                                }
                                else
                                {
                                    @book.PagesNumber
                                }
                            </td>

                            <td>
                                @if (Model.EditingBookId == book.BookId)
                                {
                                    <input type="hidden" name="Available" value="false" />
                                    <input type="checkbox" name="Available" value="true" @(book.Available ? "checked" : null) />
                                }
                                else
                                {
                                    @(book.Available ? "Tak" : "Nie")
                                }
                            </td>

                            <td>
                                <button type="submit"
                                        formaction="@Url.Action("Delete", "Book")"
                                        formmethod="post"
                                        name="id"
                                        value="@book.BookId"
                                        class="btn btn-link p-0"
                                        onclick="return confirm('Czy na pewno chcesz usunąć tę książkę?')">
                                    Usuń
                                </button>

                                |

                                <a asp-action="Edit" asp-route-id="@book.BookId">Edytuj</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (Model.EditingBookId != null)
            {
                <div class="text-center mt-3">
                    <button type="submit" class="btn btn-primary general-settings-btn">Zapisz</button>
                </div>
            }
        </form>
    </div>
</section>