@model LibraryManagerApp.Models.ViewModels.AuthorIndexViewModel


@{
	ViewData["Title"] = "Lista autorów";
}

<section class="authors-page">


	<div class="author-form-box">

		<h3>Dodaj nowego autora</h3>

		<form asp-action="Add" method="post">
			<div class="form-group">
				<label asp-for="NewAuthor.FirstName">Imię</label>
				<input asp-for="NewAuthor.FirstName" class="form-control" name="FirstName" />
			</div>
			<div class="form-group">
				<label asp-for="NewAuthor.LastName">Nazwisko</label>
				<input asp-for="NewAuthor.LastName" class="form-control" name="LastName" />
			</div>
			<button type="submit" class="btn btn-primary author-action-btn">Dodaj</button>
		</form>

	</div>



	<div class="authors-table-box">
		<h2>@ViewData["Title"]</h2>

		<table class="table table-bordered">
			<thead>
				<tr>
					<th>Id</th>
					<th>Imię</th>
					<th>Nazwisko</th>
					<th>Akcje</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var author in Model.Authors)
				{
					<tr>
						<td>@author.Id</td>
						<td>@author.FirstName</td>
						<td>@author.LastName</td>
						<td>
							<a asp-action="Details" asp-route-id="@author.Id">Szczegóły</a> |
							<form asp-action="Delete" method="post" style="display:inline;">
								@Html.AntiForgeryToken()
								<input type="hidden" name="id" value="@author.Id" />
								<button type="submit" class="btn btn-link p-0" onclick="return confirm('Czy na pewno chcesz usunąć tego autora?')">Usuń</button>
							</form>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>

	<div class="text-center">
		<a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary mb-3 mt-5">Powrót do dashboard</a>
	</div>


</section>
