@model LibraryManagerApp.Models.ViewModels.BookIndexViewModel

@{
	ViewData["Title"] = "Books";
}

<section class="books-page">



	<div class="books-form-box">

		<h2>Dodaj nową książkę</h2>


		<form asp-controller="Book" asp-action="Add" method="post">
			@Html.AntiForgeryToken()


			<div class="form-group">
				<label for="title">Tytuł: </label>
				<input type="text" id="title" name="Title" class="form-control" />
			</div>

			<div class="form-group">
				<label for="categoryId">Kategoria: </label>
				<select id="categoryId" name="CategoryId" class="form-control">

					@foreach (var category in Model.Categories)
					{
						<option value="@category.CategoryId">@category.Name</option>
					}


				</select>
			</div>

			<div class="form-group">
				<label for="year">Rok wydania: </label>
				<input type="number" id="year" name="PublishYear" class="form-control" />
			</div>

			<div class="form-group">
				<label for="isbn">ISBN: </label>
				<input type="text" id="isbn" name="ISBN" class="form-control" />
			</div>

			<div class="form-group">
				<label for="publisher">Wydawca: </label>
				<input type="text" id="publisher" name="Publisher" class="form-control" />
			</div>

			<div class="form-group">
				<label for="pagesNumber">Liczba stron: </label>
				<input type="number" id="pagesNumber" name="PagesNumber" class="form-control" />
			</div>

			<div class="form-group">
				<div class="form-check">
					
					<input type="checkbox" id="available" name="Available" value="true" class="form-check-input" />
					<input type="hidden" name="Available" value="false" />
					<label for="available" class="form-check-label"> Dostępna </label>

				</div>
			</div>




			<div class="text-center mt-3">

				<button type="submit" class="btn btn-primary general-settings-btn">Dodaj</button>

			</div>


		</form>


	</div>






	<div class="books-table-box">

		<h2>Lista książek</h2>

		<form asp-controller="Book" asp-action="Update" method="post">
			@Html.AntiForgeryToken()

			<table class="table table-bordered">
				<thead>
					<tr>
						<th>Id</th>
						<th>Tytuł</th>
						<th>Kategoria</th>
						<th>Rok wydania</th>
						<th>ISBN</th>
						<th>Wydawca</th>
						<th>Liczba stron</th>
						<th>Dostępna</th>
						<th>Akcje</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var book in Model.Books)
					{
						<tr>
							<td>
								@book.BookId
								@if (Model.EditingBookId == book.BookId)
								{
									<input type="hidden" name="BookId" value="@book.BookId" />
								}
							</td>

							<td>
								@if (Model.EditingBookId == book.BookId)
								{
									<input type="text" name="Title" value="@book.Title" class="form-control" />
								}
								else
								{
									@book.Title
								}
							</td>

							<td>
								@if (Model.EditingBookId == book.BookId)
								{
									<select name="CategoryId" class="form-control">
										@foreach (var category in Model.Categories)
										{
											@if (category.CategoryId == book.CategoryId)
											{
												<option value="@category.CategoryId" selected>@category.Name</option>
											}
											else
											{
												<option value="@category.CategoryId">@category.Name</option>
											}
										}
									</select>
								}
								else
								{
									@book.Category?.Name
								}
							</td>

							<td>
								@if (Model.EditingBookId == book.BookId)
								{
									<input type="number" name="PublishYear" value="@book.PublishYear" class="form-control" />
								}
								else
								{
									@book.PublishYear
								}
							</td>

							<td>
								@if (Model.EditingBookId == book.BookId)
								{
									<input type="text" name="ISBN" value="@book.ISBN" class="form-control" />
								}
								else
								{
									@book.ISBN
								}
							</td>

							<td>
								@if (Model.EditingBookId == book.BookId)
								{
									<input type="text" name="Publisher" value="@book.Publisher" class="form-control" />
								}
								else
								{
									@book.Publisher
								}
							</td>

							<td>
								@if (Model.EditingBookId == book.BookId)
								{
									<input type="number" name="PagesNumber" value="@book.PagesNumber" class="form-control" />
								}
								else
								{
									@book.PagesNumber
								}
							</td>

							<td>
								@if (Model.EditingBookId == book.BookId)
								{

									<input type="checkbox" name="Available" value="true" @(book.Available ? "checked" : null) />
									<input type="hidden" name="Available" value="false" />
								}
								else
								{
									@(book.Available ? "Tak" : "Nie")
								}
							</td>

							<td>
								<button type="submit"
										formaction="@Url.Action("Delete", "Book")"
										formmethod="post"
										name="id"
										value="@book.BookId"
										class="btn btn-link p-0"
										onclick="return confirm('Czy na pewno chcesz usunąć tę książkę?')">
									Usuń
								</button>

								|

								<a asp-action="Edit" asp-route-id="@book.BookId">Edytuj</a>
							</td>
						</tr>
					}
				</tbody>
			</table>

			@if (Model.EditingBookId != null)
			{
				<div class="text-center mt-3">
					<button type="submit" class="btn btn-primary general-settings-btn">Zapisz</button>
					<a asp-action="Index" class="btn btn-secondary" style="margin-top: 12px;">Powrót</a>
				</div>

			}
		</form>




	</div>


	@if (Model.EditingBookId == null)
	{
		<div class="text-center mt-3">
			<a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Powrót do dashboard</a>
		</div>

	}


</section>